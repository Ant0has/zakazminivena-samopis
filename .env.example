# Email-канал заявок с формы заказа
# Скопируйте этот файл в .env на YandexServer и заполните значения.
# Без этих переменных API /api/order работает в режиме «лог в консоль»
# (лиды видны в `pm2 logs zakazminivena`), но email не отправляется.

# Куда отправлять заявки
ORDER_EMAIL_TO=orders@zakazminivena.ru

# SMTP-сервер (примеры):
#   smtp.yandex.ru   (Yandex Mail, порт 465 secure)
#   smtp.gmail.com   (Gmail, порт 587 STARTTLS) — нужен пароль приложения
#   smtp.mail.ru     (Mail.ru, порт 465 secure)
ORDER_SMTP_HOST=smtp.yandex.ru
ORDER_SMTP_PORT=465
ORDER_SMTP_USER=
ORDER_SMTP_PASSWORD=
ORDER_SMTP_FROM=
